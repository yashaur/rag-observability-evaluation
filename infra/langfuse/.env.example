# infra/langfuse/.env.example — copy to `.env` (gitignored) and fill in.
#
#   cp infra/langfuse/.env.example infra/langfuse/.env
#
# Then run compose pointing at it:
#   docker compose --env-file infra/langfuse/.env -f infra/langfuse/docker-compose.yml up -d
#
# Thanks to the adapted compose, DATABASE_URL and all S3 credentials are DERIVED from the
# values below — so this is the complete, minimal set you need to set. (Anything not here
# uses a safe non-secret default baked into docker-compose.yml.)

# =============================================================================
# A. Server secrets — consumed by the Langfuse stack (docker-compose.yml)
#    Generate each 32-byte secret with:  openssl rand -hex 32
# =============================================================================

# --- App secrets (do NOT use quotes; values are substituted verbatim) ---
NEXTAUTH_SECRET=__run: openssl rand -hex 32__
SALT=__run: openssl rand -hex 32__
ENCRYPTION_KEY=__run: openssl rand -hex 32__   # MUST be exactly 64 hex chars (openssl rand -hex 32)

# --- Postgres (OLTP) — DATABASE_URL is derived from these in the compose file ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=__choose a long random password__
POSTGRES_DB=postgres

# --- ClickHouse (OLAP) ---
CLICKHOUSE_USER=clickhouse
CLICKHOUSE_PASSWORD=__choose a long random password__

# --- Redis (queue/cache) ---
REDIS_AUTH=__choose a long random password__

# --- MinIO (blob storage) — all three S3 secret keys are derived from these ---
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=__choose a long random password__

# =============================================================================
# B. Client config — consumed by OUR Python (eval harness here + the RAG hook),
#    NOT by the docker stack. Self-hosted → point local. Fill the keys in AFTER
#    first boot: UI → create org → project → Settings → API Keys → create → copy.
#    Paste the SAME pair into the RAG repo's env so the observability hook reports here.
#    ⚠️  NEVER put real keys in this committed template — put them only in .env (gitignored).
# =============================================================================
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...

# =============================================================================
# C. OPTIONAL — auto-provision org/project/user + FIX the API keys at boot,
#    skipping the manual UI step. Leave commented to use the UI flow (recommended
#    first time so you see how orgs/projects/keys work). If you uncomment these,
#    set the public/secret keys above to the SAME values you choose here.
# =============================================================================
# LANGFUSE_INIT_ORG_ID=local
# LANGFUSE_INIT_ORG_NAME=Local
# LANGFUSE_INIT_PROJECT_ID=rag-eval
# LANGFUSE_INIT_PROJECT_NAME=rag-eval-observability
# LANGFUSE_INIT_PROJECT_PUBLIC_KEY=pk-lf-...
# LANGFUSE_INIT_PROJECT_SECRET_KEY=sk-lf-...
# LANGFUSE_INIT_USER_EMAIL=you@example.com
# LANGFUSE_INIT_USER_NAME=You
# LANGFUSE_INIT_USER_PASSWORD=__choose a password__
