# infra/langfuse/.env.example — copy to `.env` (gitignored) and fill in.
#
# This file configures the SELF-HOSTED Langfuse stack owned by THIS repo (ARCHITECTURE §5).
# The RAG app does NOT own Langfuse — it only points at it via LANGFUSE_HOST + the keys
# you create in the UI after first boot.

# =============================================================================
# 1. Connection (shared by the eval harness here AND the RAG app's hook)
# =============================================================================
LANGFUSE_HOST=http://localhost:3000
# Created in the Langfuse UI after first boot: Project → Settings → API Keys.
# Paste the SAME pair into the RAG repo's env (for the observability hook).
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...

# =============================================================================
# 2. Server secrets — generate each with:  openssl rand -hex 32
# =============================================================================
NEXTAUTH_SECRET=__generate__
SALT=__generate__
ENCRYPTION_KEY=__generate__
NEXTAUTH_URL=http://localhost:3000

# =============================================================================
# 3. Backing services (Langfuse v3 — Postgres + ClickHouse + Redis + S3/MinIO)
#    Fill these in to match the official v3 docker-compose you wire up in Phase 0.
#    If you drop to the v2 Postgres-only fallback, only DATABASE_URL is needed.
# =============================================================================
# --- Postgres ---
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/postgres

# --- ClickHouse (v3 only) ---
CLICKHOUSE_URL=http://clickhouse:8123
CLICKHOUSE_USER=clickhouse
CLICKHOUSE_PASSWORD=__generate__

# --- Redis (v3 only) ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_AUTH=__generate__

# --- S3 / MinIO blob storage (v3 only) ---
LANGFUSE_S3_EVENT_UPLOAD_BUCKET=langfuse
LANGFUSE_S3_EVENT_UPLOAD_ENDPOINT=http://minio:9000
LANGFUSE_S3_EVENT_UPLOAD_ACCESS_KEY_ID=minio
LANGFUSE_S3_EVENT_UPLOAD_SECRET_ACCESS_KEY=__generate__
